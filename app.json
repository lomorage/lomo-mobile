{
  "expo": {
    "name": "lomo-mobile",
    "slug": "lomo-mobile",
    "version": "1.0.134",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1b33"
    },
    "ios": {
      "buildNumber": "6",
      "supportsTablet": true,
      "bundleIdentifier": "com.wtao.lomo",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "Lomorage requires local network access to discover your server.",
        "NSBonjourServices": [
          "_lomod._tcp."
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.wtao.lomo",
      "versionCode": 1000134
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Lomorage to access your photos.",
          "savePhotosPermission": "Allow Lomorage to save photos to your library.",
          "isAccessMediaLocationEnabled": true,
          "isStandard": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Lomorage to access your photos.",
          "cameraPermission": "Allow Lomorage to take photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Lomorage to use your location."
        }
      ],
      "expo-secure-store",
      "expo-task-manager",
      "expo-background-task",
      "expo-sqlite",
      "./plugins/withWorkManagerForeground",
      "./plugins/withVideoCacheGradle"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "aed6e65d-1811-4808-9639-10d8a473ae1f"
      }
    }
  }
}
